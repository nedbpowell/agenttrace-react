{
  "name": "agenttrace-langgraph",
  "version": "0.0.1",
  "description": "LangGraph JS adapter for agenttrace-react. Visualise LangGraph agent execution traces, tool calls, and human-in-the-loop interrupts as a live React UI.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/nedbpowell/agenttrace-react.git"
  },
  "keywords": [
    "react",
    "typescript",
    "langgraph",
    "langchain",
    "ai-agents",
    "agent-ui",
    "human-in-the-loop",
    "hitl",
    "execution-trace",
    "agent-trace",
    "headless",
    "llm",
    "ai",
    "interrupt",
    "approval-gate",
    "workflow",
    "agenttrace-react"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch",
    "lint": "eslint src --ext .ts,.tsx",
    "test": "vitest run"
  },
  "dependencies": {
    "agenttrace-react": "workspace:*"
  },
  "peerDependencies": {
    "@langchain/langgraph": "^0.2.0",
    "react": "^18.2.0 || ^19.0.0"
  }
}