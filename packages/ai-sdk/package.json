{
  "name": "agenttrace-ai-sdk",
  "version": "0.0.1",
  "description": "Vercel AI SDK adapter for agenttrace-react.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/nedbpowell/agenttrace-react.git"
  },
  "homepage": "https://github.com/nedbpowell/agenttrace-react/tree/main/packages/ai-sdk",
  "bugs": {
    "url": "https://github.com/nedbpowell/agenttrace-react/issues"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch",
    "lint": "eslint src --ext .ts,.tsx",
    "test": "vitest run"
  },
  "dependencies": {
    "agenttrace-react": "workspace:*"
  },
  "peerDependencies": {
    "ai": "^5.0.0",
    "react": "^18.2.0 || ^19.0.0"
  }
}
